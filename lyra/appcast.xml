<?xml version="1.0" encoding="utf-8"?>
<!--
  Lyra appcast — host this file at:
  https://headroomstudio.dev/lyra/appcast.xml

  How to update for a new release:
  1. Run: make release  →  produces Lyra.dmg
  2. Upload Lyra.dmg to Cloudflare R2 as Lyra-X.Y.dmg, copy the public URL
  3. Get the file size in bytes:  wc -c < Lyra.dmg
  4. Sign the DMG with Sparkle:   .build/artifacts/sparkle/Sparkle/bin/sign_update Lyra.dmg
     (this prints the edSignature value)
  5. Add a new <item> block at the top (keep old items for reference)
  6. Push to your GitHub Pages repo — CloudFront picks it up automatically
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
    <channel>
        <title>Lyra</title>
        <link>https://headroomstudio.dev/lyra</link>
        <description>Lyra — UA Apollo keyboard volume control</description>
        <language>en</language>

        <item>
            <title>Version 1.0</title>
            <pubDate>Fri, 13 Mar 2026 00:00:00 +0000</pubDate>
            <sparkle:version>1</sparkle:version>
            <sparkle:shortVersionString>1.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>12.0</sparkle:minimumSystemVersion>
            <enclosure
                url="https://releases.headroomstudio.dev/Lyra-1.0.dmg"
                sparkle:edSignature="REPLACE_WITH_EDSIGNATURE"
                length="REPLACE_WITH_BYTES"
                type="application/octet-stream" />
        </item>

    </channel>
</rss>
